# Bot de Telegram - Aviones Molones
# Copia este archivo a .env y rellena los valores

# Token del bot de Telegram (obtenlo de @BotFather)
TELEGRAM_BOT_TOKEN=tu_token_aqui

# Tu chat ID de Telegram (puedes obtenerlo hablando con @userinfobot)
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# Coordenadas de tu casa (por defecto ya están puestas las tuyas)
LATITUDE=39.48837067281416
LONGITUDE=-0.4808438442805943

# Radio de detección en millas náuticas (27nm ≈ 50km)
RADIUS_NM=27

# Intervalo de revisión en minutos
CHECK_INTERVAL_MINUTES=5

# Cooldown de notificación por avión en minutos (evita spam)
COOLDOWN_MINUTES=30
